# Telegram Bot Token (обязательно)
BOT_TOKEN=your_telegram_bot_token_here

# Ключ шифрования Fernet (обязательно)
# Генерация: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# ID администраторов через запятую (опционально)
ADMIN_IDS=123456789,987654321

# Уровень логирования (опционально)
LOG_LEVEL=INFO

# Интервал проверки уведомлений в секундах (опционально)
CHECK_INTERVAL_SECONDS=300
